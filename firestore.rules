rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────

    // Is the request from a signed-in user?
    function isAuth() {
      return request.auth != null;
    }

    // Is the signed-in user a member of this family?
    function isFamilyMember(familyId) {
      return isAuth() &&
        request.auth.uid in get(/databases/$(database)/documents/families/$(familyId)).data.members;
    }

    // Is the signed-in user the owner of this document?
    function isOwner(uid) {
      return isAuth() && request.auth.uid == uid;
    }

    // Is the signed-in user an admin of this family?
    function isFamilyAdmin(familyId) {
      return isAuth() &&
        isFamilyMember(familyId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    // Is the signed-in user an admin or parent of this family?
    function isFamilyAdminOrParent(familyId) {
      return isAuth() &&
        isFamilyMember(familyId) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'parent'];
    }

    // ── Users ─────────────────────────────────────────────────────────────────

    match /users/{uid} {
      // Users can read and write their own profile
      allow read, write: if isOwner(uid);
      // Family members can read other members' profiles (for member lists)
      allow read: if isAuth() &&
        resource.data.familyId != null &&
        isFamilyMember(resource.data.familyId);
      // Family admin can update the role field on any member in their family
      allow update: if isAuth() &&
        resource.data.familyId != null &&
        isFamilyAdmin(resource.data.familyId) &&
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role']);

      // Tile preferences — private to the user
      match /prefs/{doc} {
        allow read, write: if isOwner(uid);
      }
    }

    // ── Families ──────────────────────────────────────────────────────────────

    match /families/{familyId} {
      // Any authenticated user can read a family doc (needed to join via invite code)
      allow read: if isAuth();
      allow create: if isAuth();
      // Members can update anything (e.g. invite code regeneration by admin)
      // Any auth user can update only the members field (adding themselves when joining)
      allow update: if isFamilyMember(familyId) ||
        (isAuth() &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['members']) &&
         request.resource.data.members.hasAll(resource.data.members));
      allow delete: if false; // never delete a family doc from the client

      // ── Settings (tileAccess, etc.) ───────────────────────────────────
      match /settings/{doc} {
        allow read: if isFamilyMember(familyId);
        allow write: if isFamilyAdmin(familyId);
      }

      // ── Live locations ────────────────────────────────────────────────────
      match /locations/{uid} {
        // Any family member can read all locations
        allow read: if isFamilyMember(familyId);
        // Only the owner can write their own location
        allow write: if isFamilyMember(familyId) && isOwner(uid);
      }

      // ── Places ───────────────────────────────────────────────────────────
      match /places/{placeId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId);
      }

      // ── Emergency contacts ────────────────────────────────────────────────
      match /emergencyContacts/{contactId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        // Admin has full control; non-admins can only edit/delete their own contacts
        allow update, delete: if isFamilyAdmin(familyId) ||
          (isFamilyMember(familyId) && request.auth.uid == resource.data.addedBy);
      }

      // ── Shopping list ─────────────────────────────────────────────────────
      match /shoppingList/{itemId} {
        allow read, create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId);
      }

      // ── Todo lists + items ────────────────────────────────────────────────
      match /todos/{listId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId) &&
          request.auth.uid == resource.data.createdBy;

        match /items/{itemId} {
          allow read: if isFamilyMember(familyId);
          allow create: if isFamilyMember(familyId);
          allow update, delete: if isFamilyMember(familyId);
        }
      }

      // ── Chores ────────────────────────────────────────────────────────────
      match /rooms/{roomId} {
        allow read, create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId);
      }

      match /chores/{choreId} {
        allow read, create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId);
      }

      match /chorePoints/{uid} {
        allow read: if isFamilyMember(familyId);
        // Any family member can write points (needed for point reversal when unmarking chores)
        allow write: if isFamilyMember(familyId);
      }

      // ── Chats ─────────────────────────────────────────────────────────────
      match /chats/{chatId} {
        allow read, create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId) &&
          request.auth.uid in resource.data.adminUids &&
          resource.data.type != 'family';

        match /messages/{messageId} {
          allow read, create: if isFamilyMember(familyId);
          allow delete: if isFamilyMember(familyId) &&
            request.auth.uid == resource.data.senderId;
        }
      }

      // ── Calendar ──────────────────────────────────────────────────────────
      match /calendarEvents/{eventId} {
        allow read, create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId) &&
          request.auth.uid == resource.data.createdBy;
      }

      // ── Document folders ──────────────────────────────────────────────────
      match /documentFolders/{folderId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId) &&
          (isFamilyAdmin(familyId) || request.auth.uid == resource.data.createdBy);
        allow delete: if isFamilyMember(familyId) &&
          (isFamilyAdmin(familyId) || request.auth.uid == resource.data.createdBy);
      }

      // ── Documents ─────────────────────────────────────────────────────────
      match /documents/{docId} {
        allow read, create: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId) &&
          (isFamilyAdmin(familyId) || request.auth.uid == resource.data.uploadedBy);
        allow update: if false;
      }

      // ── Budget ────────────────────────────────────────────────────────────
      match /budgetCategories/{categoryId} {
        allow read, create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId);
      }

      match /transactions/{txnId} {
        allow read, create: if isFamilyMember(familyId);
        allow update: if isFamilyMember(familyId) &&
          request.auth.uid == resource.data.addedBy;
        allow delete: if isFamilyAdminOrParent(familyId) ||
          (isFamilyMember(familyId) && request.auth.uid == resource.data.addedBy);
      }

      // ── Gallery ───────────────────────────────────────────────────────────
      match /photos/{photoId} {
        allow read, create: if isFamilyMember(familyId);
        allow delete: if isFamilyMember(familyId) &&
          request.auth.uid == resource.data.uploadedBy;
        allow update: if false;
      }

      // ── Recipes ───────────────────────────────────────────────────────────
      match /recipes/{recipeId} {
        allow read, create: if isFamilyMember(familyId);
        allow update, delete: if isFamilyMember(familyId) &&
          request.auth.uid == resource.data.createdBy;
      }

      // ── Activity feed ─────────────────────────────────────────────────────
      match /activity/{activityId} {
        allow read: if isFamilyMember(familyId);
        allow create: if isFamilyMember(familyId);
        allow delete: if isFamilyAdminOrParent(familyId);
        allow update: if false;
      }
    }

    // Deny everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
