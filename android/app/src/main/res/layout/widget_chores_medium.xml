<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:id="@+id/widget_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Today's Chores"
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_add_btn"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#FFFFFF"
            android:gravity="center"
            android:textStyle="bold" />

    </LinearLayout>

    <!-- Chore rows -->
    <LinearLayout android:id="@+id/chore_row_1"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingVertical="4dp">
        <ImageView android:id="@+id/chore_check_1"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/widget_check_off" android:layout_marginEnd="10dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/chore_name_1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/chore_room_1"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#CCFFFFFF" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/chore_row_2"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingVertical="4dp">
        <ImageView android:id="@+id/chore_check_2"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/widget_check_off" android:layout_marginEnd="10dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/chore_name_2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/chore_room_2"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#CCFFFFFF" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/chore_row_3"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingVertical="4dp">
        <ImageView android:id="@+id/chore_check_3"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/widget_check_off" android:layout_marginEnd="10dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/chore_name_3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/chore_room_3"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#CCFFFFFF" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/chore_row_4"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingVertical="4dp">
        <ImageView android:id="@+id/chore_check_4"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/widget_check_off" android:layout_marginEnd="10dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/chore_name_4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/chore_room_4"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#CCFFFFFF" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <LinearLayout android:id="@+id/chore_row_5"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:paddingVertical="4dp">
        <ImageView android:id="@+id/chore_check_5"
            android:layout_width="32dp" android:layout_height="32dp"
            android:src="@drawable/widget_check_off" android:layout_marginEnd="10dp" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical">
            <TextView android:id="@+id/chore_name_5"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="13sp" android:textColor="#FFFFFF" android:maxLines="1" android:ellipsize="end" />
            <TextView android:id="@+id/chore_room_5"
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:textSize="11sp" android:textColor="#CCFFFFFF" android:maxLines="1" android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>

    <!-- Footer -->
    <TextView
        android:id="@+id/widget_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:textSize="11sp"
        android:textColor="#CCFFFFFF"
        android:maxLines="1"
        android:ellipsize="end" />

</LinearLayout>
